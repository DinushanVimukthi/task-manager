{
  "$schema": "https://schema.tauri.app/config/2.json",
  "productName": "Task Manager",
  "version": "0.1.0",
  "identifier": "com.taskmanager.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Task Manager",
        "width": 1100,
        "height": 740,
        "minWidth": 760,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
